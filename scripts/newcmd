#!/usr/bin/env bash
set -euo pipefail

old_name='node-cmd-skel'
old_repo='djnz00/node-cmd-skel'
old_tap_repo='djnz00/homebrew-djnz00'
old_tap_short='djnz00/djnz00'
old_tap_badge='djnz00%2Fdjnz00'

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root_dir="$(cd "${script_dir}/.." && pwd)"

cd "${root_dir}"

repo_name="$(basename "${root_dir}")"

if [[ -z "${repo_name}" ]]; then
  echo "Could not derive a command name from the repository basename." >&2
  exit 1
fi

if [[ ! "${repo_name}" =~ ^[a-z][a-z0-9-]*$ ]]; then
  echo "Derived command name '${repo_name}' contains unsupported characters." >&2
  exit 1
fi

origin_url="$(git remote get-url origin 2>/dev/null || true)"
if [[ -z "${origin_url}" ]]; then
  echo "scripts/newcmd requires an origin remote so repository metadata can be updated." >&2
  exit 1
fi

if [[ "${origin_url}" =~ github\.com[:/]([^/]+)/([^/.]+)(\.git)?$ ]]; then
  repo_owner="${BASH_REMATCH[1]}"
  repo_slug="${BASH_REMATCH[2]}"
else
  echo "Could not parse a GitHub owner/repo from origin: ${origin_url}" >&2
  exit 1
fi

new_repo="${repo_owner}/${repo_slug}"

read -r -p 'Homebrew tap (owner/tap): ' tap_input

if [[ ! "${tap_input}" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
  echo "Tap must be provided as owner/tap." >&2
  exit 1
fi

tap_owner="${tap_input%%/*}"
tap_value="${tap_input#*/}"

if [[ "${tap_value}" == homebrew-* ]]; then
  tap_short_name="${tap_value#homebrew-}"
  tap_repo_name="${tap_value}"
else
  tap_short_name="${tap_value}"
  tap_repo_name="homebrew-${tap_value}"
fi

new_tap_short="${tap_owner}/${tap_short_name}"
new_tap_repo="${tap_owner}/${tap_repo_name}"
new_tap_badge="${new_tap_short//-/--}"
new_tap_badge="${new_tap_badge//\//%2F}"

rewrite_literal() {
  local file_path="$1"
  local old_value="$2"
  local new_value="$3"

  node --input-type=module - "${file_path}" "${old_value}" "${new_value}" <<'EOF'
import { readFile, writeFile } from 'node:fs/promises';

const [filePath, oldValue, newValue] = process.argv.slice(2);
const source = await readFile(filePath, 'utf8');
if (!source.includes(oldValue))
  process.exit(0);

await writeFile(filePath, source.split(oldValue).join(newValue));
EOF
}

rewrite_block() {
  local file_path="$1"
  local marker_name="$2"

  node --input-type=module - "${file_path}" "${marker_name}" <<'EOF'
import { readFile, writeFile } from 'node:fs/promises';

const [filePath, markerName] = process.argv.slice(2);
const source = await readFile(filePath, 'utf8');
const start = `<!-- ${markerName}:START -->`;
const end = `<!-- ${markerName}:END -->`;
const pattern = new RegExp(`\\n?${start}[\\s\\S]*?${end}\\n?`, 'g');

await writeFile(filePath, source.replace(pattern, '\n'));
EOF
}

rewrite_json_package() {
  node --input-type=module - "${root_dir}" "${repo_name}" "${new_repo}" <<'EOF'
import { readFile, writeFile } from 'node:fs/promises';
import path from 'node:path';

const [rootDir, commandName, repository] = process.argv.slice(2);
const packagePath = path.join(rootDir, 'package.json');
const packageJson = JSON.parse(await readFile(packagePath, 'utf8'));

packageJson.name = commandName;
packageJson.bin = { [commandName]: `./${commandName}` };
packageJson.homepage = `https://github.com/${repository}#readme`;
packageJson.repository = {
  type: 'git',
  url: `git+https://github.com/${repository}.git`
};
packageJson.bugs = {
  url: `https://github.com/${repository}/issues`
};

await writeFile(packagePath, `${JSON.stringify(packageJson, null, 2)}\n`);
EOF
}

known_files=(
  README.md
  docs/distribution.md
  lib/project.js
  lib/help.js
  lib/version.js
  Makefile
  package.json
  .github/workflows/ci.yml
  .github/workflows/release.yml
  scripts/build-dist.mjs
  scripts/build-release-assets.mjs
  scripts/build-release-candidate.mjs
  scripts/project-meta.mjs
  scripts/render-homebrew-formula.mjs
  scripts/versioning.mjs
  scripts/bump
  tests/cli.test.js
  tests/versioning.test.js
  tests/release-assets.test.js
  tests/render-homebrew-formula.test.js
  tests/newcmd.test.js
  tests/fixtures/newcmd/exempt-paths.txt
)

for file_path in "${known_files[@]}"; do
  if [[ -f "${file_path}" ]]; then
    rewrite_literal "${file_path}" "${old_tap_badge}" "${new_tap_badge}"
    rewrite_literal "${file_path}" "${old_tap_repo}" "${new_tap_repo}"
    rewrite_literal "${file_path}" "${old_tap_short}" "${new_tap_short}"
    rewrite_literal "${file_path}" "${old_repo}" "${new_repo}"
    rewrite_literal "${file_path}" "${old_name}" "${repo_name}"
  fi
done

rewrite_json_package

if [[ -f "${old_name}" && "${old_name}" != "${repo_name}" ]]; then
  mv "${old_name}" "${repo_name}"
fi

validate_output() {
  local matches

  matches="$(
    git ls-files | while IFS= read -r tracked_path; do
      case "${tracked_path}" in
        goal.md|develop_*.md|implement_plan.md|iterate_*.md|plan*.md|requirements*.md|scripts/newcmd)
          continue
          ;;
      esac
      printf '%s\0' "${tracked_path}"
    done | xargs -0 rg -n --fixed-strings "${old_name}" 2>/dev/null || true
  )"

  if [[ -n "${matches}" ]]; then
    echo "Rename completed, but the old skeleton name still appears in tracked files:" >&2
    echo "${matches}" >&2
    exit 1
  fi
}

validate_output

if [[ "${NEWCMD_TEST_HARNESS:-}" != '1' ]]; then
  read -r -p 'Remove scripts/newcmd and its dedicated tests from this cloned repo? [Y/n] ' cleanup_reply

  case "${cleanup_reply:-Y}" in
    Y|y|yes|YES|'')
      rm -f scripts/newcmd tests/newcmd.test.js
      rm -rf tests/fixtures/newcmd
      rewrite_block README.md 'NEWCMD'
      rewrite_block docs/distribution.md 'NEWCMD'
      ;;
    *)
      ;;
  esac
fi

printf 'Rebranded %s as %s.\n' "${old_name}" "${repo_name}"
printf 'Repository metadata: %s\n' "${new_repo}"
printf 'Homebrew install target: brew install %s/%s\n' "${new_tap_short}" "${repo_name}"
